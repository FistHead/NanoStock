{
  "model_id": "minimip",
  "architecture": "MiniMip",
  "embedding_dim": 512,
  "n_heads": 16,
  "block_size": 256,
  "n_layers": 8,
  "sentimens_count": 7,
  "emotions_count": 3,
  "stock_signs_count": 2,
  "max_stocks": 8,
  "checkpoint": "minimip_finetuned_cpu.pth",
  "checkpoint_fallback": "minimip_pretrained.pth",
  "tokenizer": "minimip_tokenizer.json",
  "inference": {
    "temperature": 0.8,
    "decision_temp": 1.2,
    "max_new": 80,
    "min_new": 5
  },
  "prompt": {
    "message_sep": "[MESSAGE]",
    "news_sep": "[NEWS]",
    "sos_token": "[SOS]",
    "eos_token": "[EOS]"
  },
  "decisions": ["buy", "sell", "hold"]
}

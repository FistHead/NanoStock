# Виртуальное окружение (самое главное!)
.venv/
venv/
ENV/

# Кэш Python (чтобы не плодились папки __pycache__)
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Настройки среды разработки (JetBrains / PyCharm / VS Code)
.idea/
.vscode/


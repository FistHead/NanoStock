@startuml miple_use_case
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Пользователь" as User

rectangle "Веб-приложение «Миплы»" {
  usecase "Просмотреть\n«О проекте»" as UC1
  usecase "Создать симуляцию" as UC2
  usecase "Переименовать\nсимуляцию" as UC3
  usecase "Удалить симуляцию" as UC4
  usecase "Создать авто-симуляцию\n(миплы + акции)" as UC5
  usecase "Добавить акцию\n(вручную / случайно)" as UC6
  usecase "Добавить мипла\n(колесо личности,\nмодель, случайный)" as UC7
  usecase "Удалить мипла" as UC8
  usecase "Заполнить симуляцию\nавтоматически" as UC9
  usecase "Открыть окно\nсимуляции" as UC10
  usecase "Делать шаг рынка\n(1 / 5 / авто-прогон)" as UC11
  usecase "Смотреть график акции\n(свечи / линия / область)" as UC12
  usecase "Фильтровать чат\nпо миплу" as UC13
  usecase "Переключить вид:\nчат / решения /\nактивы / события" as UC14
  usecase "Открыть профиль мипла\n(богатство, портфель)" as UC14b
  usecase "Развернуть планету\n(заглушка 3D)" as UC15
  usecase "Переключить\nсветлую/тёмную тему" as UC16
}

rectangle "Система (фон)" <<system>> {
  usecase "Генерировать решения\nи реплики миплов" as SYS1
  usecase "Исполнять сделки\n(стакан + ядро)" as SYS2
  usecase "Применять рыночные\nсобытия" as SYS3
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC11
User --> UC12
User --> UC13
User --> UC14
User --> UC14b
User --> UC15
User --> UC16

UC10 ..> UC11 : include
UC10 ..> UC12 : include
UC10 ..> UC14 : include
UC11 ..> SYS1 : <<include>>
UC11 ..> SYS2 : <<include>>
UC11 ..> SYS3 : <<extend>>

UC2 <.. UC6 : extend
UC2 <.. UC7 : extend
UC5 ..> UC2 : include

@enduml
